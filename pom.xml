    <module>vertx-auth-htpasswd-shaded</module>
    <module>vertx-auth-webauthn-shaded</module>
    <module>vertx-auth-properties-shaded</module>
    <module>vertx-auth-sql-client-shaded</module>
    <module>vertx-auth-otp-shaded</module>
    <module>vertx-bridge-common-shaded</module>
    <module>vertx-camel-bridge-shaded</module>
    <module>vertx-tcp-eventbus-bridge-shaded</module>
    <module>vertx-stomp-shaded</module>
    <module>vertx-mqtt-shaded</module>
    <module>vertx-circuit-breaker-shaded</module>
    <module>vertx-health-check-shaded</module>
    <module>vertx-config-shaded</module>
    <module>vertx-config-consul-shaded</module>
    <module>vertx-config-git-shaded</module>
